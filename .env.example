# OccasionPro environment template.
# Copy to `.env.local` for dev. NEVER commit secrets.

# ---- Database --------------------------------------------------------------
# Supabase Postgres — service-role connection string used by Drizzle for
# migrations and server-side queries from Cloudflare Workers. Postgres-js
# is configured for transaction pooling (port 6543) in prod.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# ---- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only. Bypasses RLS. Root credential.
SUPABASE_SERVICE_ROLE_KEY=

# ---- App environment -------------------------------------------------------
# local | dev | staging | production
APP_ENV=local

# ---- Observability (Part 21.1) --------------------------------------------
# All four are optional in local; CI/staging/prod fill them in.
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
BETTERSTACK_HEARTBEAT_URL=
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_TOKEN=

# ---- Payments --------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Email / SMS / WhatsApp ------------------------------------------------
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
MSG91_AUTH_KEY=

# ---- Storage ---------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ---- Auth ------------------------------------------------------------------
WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# ---- E-Sig -----------------------------------------------------------------
DOCUSIGN_INTEGRATION_KEY=
SIGNWELL_API_KEY=
