# OccasionPro environment template.
# Copy to `.env.local` for dev. NEVER commit secrets.

# Supabase Postgres — service-role connection string used by Drizzle for
# migrations and server-side queries from Cloudflare Workers. Postgres-js
# client is configured for transaction pooling (port 6543) in prod.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Supabase public anon key — used only by the Next.js client. Never used
# by the worker tier.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only. Bypasses RLS. Treat as a root credential.
SUPABASE_SERVICE_ROLE_KEY=
